{
    "services": {
        "frontend": {
            "root": "frontend/"
        },
        "backend": {
            "root": "backend/",
            "entrypoint": "src/main.ts"
        }
    },
    "rewrites": [
        {
            "source": "/_/backend/(.*)",
            "destination": {
                "service": "backend"
            }
        },
        {
            "source": "/(.*)",
            "destination": {
                "service": "frontend"
            }
        }
    ]
}
